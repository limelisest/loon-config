# NAME: limelisest-loon-config
# Author:https://github.com/Repcz
# TG:https://t.me/LUCYChannel_1024
# 最后更新时间: 2026-6-29 19:50
#
# Loon Version ≥ 3.2.3
# 基于[@iKeLee](https://gitlab.com/lodepuly/vpn_tool/-/blob/main/Tool/Loon/Config/Loon_Simple_Sample_Configuration_By_iKeLee.conf)修改
#
# 以 ';' 或 '#' 或 '//' 开头的配置文件行为注释行
#
# ================

[General]
# IP 模式: ipv4-only / dual / ipv4-preferred / ipv6-preferred
ip-mode = ipv4-only
# DNS 服务，system 表示系统自带 DNS 服务器
dns-server = 223.5.5.5,119.29.29.29
# 测试链接
proxy-test-url = http://1.1.1.1/generate_204
internet-test-url = http://wifi.vivo.com.cn/generate_204
# 策略切换时关闭连接
disconnect-on-policy-change = true
# 默认节点超时时间（秒）
test-timeout = 5
# 域名拦截行为
domain-reject-mode = DNS
# DNS 拒绝行为
dns-reject-mode = LOOPBACKIP
# SNI 辅助规则匹配
sni-sniffing = true
# UDP 回落策略
udp-fallback-mode = REJECT
# 网络接口
interface-mode = auto
# 自定义 GeoIP 数据库
geoip-url = https://raw.githubusercontent.com/Loyalsoldier/geoip/release/Country-without-asn.mmdb
# 自定义 ASN 数据库
ipasn-url = https://raw.githubusercontent.com/Loyalsoldier/geoip/release/GeoLite2-ASN.mmdb

[Proxy]

[Remote Proxy]

[Remote Filter]
All = NameRegex, FilterKey = .
HK = NameRegex, FilterKey = "(?i)🇭🇰|香港|(\b(HK|Hong)\b)"
US = NameRegex, FilterKey = "(?i)🇺🇸|美国|洛杉矶|圣何塞|(\b(US|United States)\b)"
SG = NameRegex, FilterKey = "(?i)🇸🇬|新加坡|狮|(\b(SG|Singapore)\b)"
JP = NameRegex, FilterKey = "(?i)🇯🇵|日本|东京|(\b(JP|Japan)\b)"
TW = NameRegex, FilterKey = "(?i)🇨🇳|🇹🇼|台湾|(\b(TW|Tai|Taiwan)\b)"

[Proxy Group]
# 基础策略：只保留一个手动选择入口「兜底后备」，默认第一项为「自动选择」
兜底后备 = select,自动选择,HongKong,United States,Singapore,Japan,Taiwan,All,DIRECT,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Final.png
自动选择 = url-test,All,url = http://1.1.1.1/generate_204,interval = 300,tolerance = 0,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Auto.png

# 分流策略组：规则按类别进入对应策略，默认都先走「兜底后备」
Streaming = select,兜底后备,HongKong,United States,Singapore,Japan,Taiwan,DIRECT,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/YouTube.png
Pixiv/booth/fanbox = select,Japan,兜底后备,HongKong,United States,Singapore,Taiwan,DIRECT,img-url = https://raw.githubusercontent.com/lige47/QuanX-icon-rule/main/icon/04ProxySoft/pixiv.png
Microsoft = select,兜底后备,HongKong,United States,Singapore,Japan,Taiwan,DIRECT,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Microsoft.png
Google = select,兜底后备,HongKong,United States,Singapore,Japan,Taiwan,DIRECT,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Google_Search.png
AI = select,兜底后备,HongKong,United States,Singapore,Japan,Taiwan,DIRECT,img-url = https://raw.githubusercontent.com/Orz-3/mini/master/Color/OpenAI.png
Social = select,兜底后备,HongKong,United States,Singapore,Japan,Taiwan,DIRECT,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Twitter.png
Telegram = select,兜底后备,HongKong,United States,Singapore,Japan,Taiwan,DIRECT,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Telegram.png
Game = select,兜底后备,HongKong,United States,Singapore,Japan,Taiwan,DIRECT,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Steam.png
Emby = select,兜底后备,All,DIRECT,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Emby.png
Spotify = select,兜底后备,HongKong,United States,Singapore,Japan,Taiwan,DIRECT,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Spotify.png

# 地区策略组
HongKong = url-test,HK,url = http://1.1.1.1/generate_204,interval = 300,tolerance = 0,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Hong_Kong.png
United States = url-test,US,url = http://1.1.1.1/generate_204,interval = 300,tolerance = 0,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/United_States.png
Singapore = url-test,SG,url = http://1.1.1.1/generate_204,interval = 300,tolerance = 0,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Singapore.png
Japan = url-test,JP,url = http://1.1.1.1/generate_204,interval = 300,tolerance = 0,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Japan.png
Taiwan = url-test,TW,url = http://1.1.1.1/generate_204,interval = 300,tolerance = 0,img-url = https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/China.png

[Rule]
FINAL,兜底后备

